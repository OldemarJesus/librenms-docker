TZ=UTC
PUID=1000
PGID=1000

APP_URL=https://librenms.techboystore.uk
MEMORY_LIMIT=256M
MAX_INPUT_VARS=1000
UPLOAD_MAX_SIZE=16M
OPCACHE_MEM_SIZE=128
REAL_IP_FROM=0.0.0.0/32
REAL_IP_HEADER=X-Forwarded-For
LOG_IP_VAR=remote_addr
SESSION_SECURE_COOKIE=true

CACHE_DRIVER=redis
SESSION_DRIVER=redis
REDIS_HOST=nas.techboystore.uk
REDIS_PORT=1003

DB_HOST=nas.techboystore.uk
DB_PORT=1000
DB_TIMEOUT=60
DB_NAME=librenms
DB_USER=librenms

LIBRENMS_SNMP_COMMUNITY=labtechboy

LIBRENMS_WEATHERMAP=false
LIBRENMS_WEATHERMAP_SCHEDULE=*/5 * * * *
